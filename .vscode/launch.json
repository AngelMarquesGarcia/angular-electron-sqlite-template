{
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Electron Main",
      "program": "${workspaceFolder}/dist/main/main.js",
      "args": ["--serve"],
      "request": "launch",
      "runtimeExecutable": "electron",
      "skipFiles": [
        "<node_internals>/**"
      ],
      "type": "node",
      "preLaunchTask": "npm: predebug:electron"
    },
    {
      "name": "Attach to Electron Renderer",
      "type": "chrome",
      "request": "attach",
      "port": 9223,
      "webRoot": "${workspaceFolder}/angular",
      "preLaunchTask": "npm: predebug:angular",
      "postDebugTask": "stop angular"
    }
  ],
  "compounds": [
    {
      "name": "Debug Full App",
      "configurations": [
        "Electron Main",
        "Attach to Electron Renderer"
      ],
      "stopAll": true
    }
  ]
}
