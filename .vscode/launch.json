{
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Attach to Chrome",
      "port": 9222,
      "request": "launch",
      "type": "chrome",
      "url": "http://localhost:4200",
      "webRoot": "${workspaceFolder}/angular",
      "preLaunchTask": "npm: ng:serve"
    },
    {
      "name": "Electron Main",
      "program": "${workspaceFolder}/electron/target/main.js",
      "args": ["--serve"],
      "request": "launch",
      "runtimeExecutable": "electron",
      "skipFiles": [
        "<node_internals>/**"
      ],
      "type": "node",
      "preLaunchTask": "npm: build:electron"
    },
    {
      "name": "Attach to Electron Renderer",
      "type": "chrome",
      "request": "attach",
      "port": 9223,
      "webRoot": "${workspaceFolder}/angular",
      "preLaunchTask": "npm: ng:serve",
      "postDebugTask": "stop angular"
    }
  ],
  "compounds": [
    {
      "name": "Debug Full App",
      "configurations": [
        "Electron Main",
        "Attach to Electron Renderer"
      ],
      "stopAll": true
    }
  ]
}
