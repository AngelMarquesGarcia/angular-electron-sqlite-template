{
  "name": "from-scratch-angular-electron",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "electron": "electron",
    "start": "npm-run-all -p electron:serve ng:serve",
    "ng:serve": "cd angular && ng serve -c development",
    "electron:serve": "wait-on tcp:4200 && npm run build:electron && electron ./electron --serve",
    "electron:local": "npm run build && electron ./electron",
    "build": "npm run build:electron && npm run build:angular",
    "build:angular": "cd angular && ng build --base-href ./ --output-path=../electron/renderer",
    "build:angular-for-package": "cd angular && ng build --base-href ./ --output-path=../electron/target/electron/renderer",
    "build:electron": "cd electron && npm run electron:serve-tsc",
    "forge-start": "cd electron && electron-forge start",
    "forge-package": "cd electron && electron-forge package",
    "forge-make": "cd electron && electron-forge make",
    "compile-and-make": "npm run build:electron && npm run build:angular-for-package && npm run forge-make ",
    "rebuild-native": "@electron/rebuild -f -w better-sqlite3"
  },
  "private": true,
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.0.0",
    "@angular/cli": "^19.0.0",
    "@angular/compiler-cli": "^19.0.0",
    "@electron-forge/cli": "^7.11.1",
    "electron": "^40.0.0",
    "kill-port": "^2.0.1",
    "npm-run-all": "^4.1.5",
    "typescript": "~5.6.2",
    "wait-on": "^9.0.3"
  },
  "dependencies": {
    "better-sqlite3": "^12.6.2"
  }
}
