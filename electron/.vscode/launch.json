{
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Electron Serve",
      "program": "${workspaceFolder}/target/main.js",
      "request": "launch",
      "runtimeExecutable": "electron",
      "skipFiles": [
        "<node_internals>/**"
      ],
      "type": "node",
      "preLaunchTask": "npm: electron:serve-tsc"
    },
    {
      "name": "Electron Local",
      "program": "${workspaceFolder}/target/main.js",
      "runtimeArgs": ["--remote-debugging-port=9223"],
      "request": "launch",
      "runtimeExecutable": "electron",
      "skipFiles": [
        "<node_internals>/**"
      ],
      "type": "node",
      "preLaunchTask": "npm: electron:serve-tsc",
      "args":["--local"]
    }
  ]
}
